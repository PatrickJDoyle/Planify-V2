# Planify V2 — copy to `.env.local` for local development (do not commit secrets).
# Vercel: set values in Project → Environment Variables; avoid relying on code fallbacks in production.

# Sandbox backend API (board canonical). Use http://localhost:3000 when running the backend locally.
NEXT_PUBLIC_BACKEND_API_URL=https://backend-api.planify.ie

# Clerk (required for auth) — see https://clerk.com/docs/quickstarts/nextjs
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# Optional — see usages in src/
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# NEXT_PUBLIC_MAPBOX_TOKEN=
# NEXT_PUBLIC_POSTHOG_KEY=
